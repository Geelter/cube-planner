{
  "name": "@cube-planner/frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "gen": "tsr generate && paraglide-js compile --project ./project.inlang --outdir ./src/paraglide --strategy localStorage preferredLanguage baseLocale --emit-ts-declarations",
    "build": "pnpm gen && tsc --noEmit && vite build",
    "typecheck": "pnpm gen && pnpm typecheck:raw",
    "typecheck:raw": "tsc --noEmit",
    "test": "vitest run",
    "lint": "oxlint .",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check ."
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.3.0",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.17",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "openapi-fetch": "^0.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@inlang/paraglide-js": "^2.21.0",
    "@inlang/plugin-message-format": "^4.4.0",
    "@tailwindcss/vite": "^4.3.2",
    "@tanstack/react-devtools": "^0.10.8",
    "@tanstack/react-query-devtools": "^5.101.2",
    "@tanstack/react-router-devtools": "^1.167.0",
    "@tanstack/router-cli": "^1.167.18",
    "@tanstack/router-plugin": "^1.168.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "happy-dom": "^20.10.6",
    "jsdom": "^29.1.1",
    "openapi-typescript": "^7.13.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "vitest-axe": "^0.1.0"
  }
}
